# PostgreSQL（Prisma + node-pg）。密码含特殊字符时请做 URL 编码。
# 例：postgresql://USER:PASSWORD@localhost:5432/novel_writer?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/novel_writer?schema=public"

# Chroma HTTP Server（向量检索 / 知识库）。本地或 Docker 启动后填写。
# 例：docker run -p 8000:8000 chromadb/chroma
CHROMA_HOST="localhost"
CHROMA_PORT="8000"
